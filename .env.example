# Copy to .env and fill in. Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# Database (required — no default)
DATABASE_URL=postgresql://finlife:CHANGE_ME@localhost:5432/finlife

# Security (required — no default)
SECRET_KEY=generate-a-random-64-char-string

# Application
TIMEZONE=Europe/Moscow
DEBUG=False
DISABLE_NOTIFICATIONS=False

# Analytics (Microsoft Clarity)
CLARITY_PROJECT_ID=
CLARITY_ENABLED=False

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@finlife.app

# Telegram Bot (for notification delivery)
TELEGRAM_BOT_TOKEN=

# Email (SMTP stub — configure to activate)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# File uploads
UPLOADS_DIR=uploads

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI commentary for weekly digest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.aitunnel.ru/v1/
ANTHROPIC_API_KEY=
