{
  "appId": "com.melekhov.finlife",
  "appName": "FinLife",
  "webDir": "www",
  "server": {
    "url": "https://centricore.ru",
    "allowNavigation": ["centricore.ru", "*.centricore.ru"]
  },
  "backgroundColor": "#FAF7FF",
  "ios": {
    "contentInset": "never"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#140E26",
      "showSpinner": false
    }
  }
}
