centricore.ru, www.centricore.ru {
  encode gzip

  # CalDAV — proxy directly to FastAPI backend (WebDAV methods: PROPFIND, REPORT, etc.)
  handle /.well-known/caldav* {
    reverse_proxy centricore_app:8000
  }
  handle /caldav* {
    reverse_proxy centricore_app:8000
  }

  reverse_proxy centricore_frontend:3000
}

mealie.centricore.ru {
  reverse_proxy 172.17.0.1:9925
}
